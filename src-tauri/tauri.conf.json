{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Supabase File Manager",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "open": true },
      "dialog": {
        "open": true,
        "save": true
      },
      "fs": {
        "readFile": true,
        "writeFile": true,
        "scope": ["$DOWNLOAD/*", "$DOCUMENT/*", "$TEMP/*"]
      },
      "http": {
        "all": true,
        "request": true,
        "scope": ["https://*.supabase.co/**"]
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.yourname.supabase-file-manager",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Supabase File Manager",
        "width": 1024,
        "height": 680,
        "minWidth": 720,
        "minHeight": 500
      }
    ]
  }
}
